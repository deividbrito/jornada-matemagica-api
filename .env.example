# ============================================================
# Jornada Matemágica API — variáveis de ambiente
# Copie este arquivo para `.env` e preencha os valores.
# NUNCA comite o `.env` real — ele está no .gitignore.
#
# NO RAILWAY: não usar .env. Definir variáveis no painel do serviço.
# Ao plugar o MySQL Railway, ele expõe MYSQLHOST/MYSQLUSER/MYSQLPASSWORD/
# MYSQLDATABASE/MYSQLPORT — referenciar com ${{ MySQL.MYSQLHOST }} etc.
# nas variáveis abaixo, OU duplicar os valores manualmente.
# ============================================================

# --- Banco de dados (MySQL) ---
# Em Railway: DB_HOST=${{ MySQL.MYSQLHOST }} (e equivalentes)
DB_HOST=localhost
DB_USER=root
DB_PASS=troque-esta-senha
DB_NAME=jornada_matemagica

# --- HTTP ---
# Em Railway: NÃO setar manualmente — Railway injeta PORT no runtime.
PORT=3000

# --- Ambiente (development | production | test) ---
# Em Railway: production
NODE_ENV=development

# --- CORS ---
# Lista de origens permitidas, separadas por vírgula.
# Em dev, usar a URL do frontend local (Vite default 5173 ou WAMP).
# Em prod, listar APENAS o(s) domínio(s) oficial(is) — ex.:
#   CORS_ORIGINS=https://jogo.up.railway.app,https://jornadamatemagica.com.br
CORS_ORIGINS=http://localhost:5173,http://localhost,http://127.0.0.1

# --- JWT (usado na Onda 2 — autenticação) ---
# Gere um valor forte e único, ex.: `node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"`
JWT_SECRET=troque-este-segredo-jwt-em-prod
JWT_EXPIRES_IN=7d
